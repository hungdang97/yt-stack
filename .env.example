# =============================================
# YT-Stack Configuration (Auto-generated by Hub)
# =============================================
# This file is automatically generated when deployed via Hub.
# For local development, copy this file to .env and customize.

# Domain Configuration
# When deployed via Hub, these are auto-generated per VPS:
# - Subdomain: vps-{unique_id}
# - Full Domain: vps-{unique_id}.ytconvert.org
DOMAIN=vps-example.ytconvert.org
BASE_URL=https://vps-example.ytconvert.org
EMAIL=admin@ytconvert.org

# Proxy Authentication (Auto-generated per VPS)
# These credentials are randomly generated by Hub for each VPS
WARP_USER=warp_user
WARP_PASS=secure_password_change_me
DIRECT_USER=direct_user
DIRECT_PASS=secure_password_change_me

# Service URLs (Internal - DO NOT CHANGE)
EXTRACTOR_URL=http://yt-extractor:8300
PROXY_URL=socks5://gost:1111

# Optional: MongoDB for cookie storage (YT-Extractor)
# MONGODB_URI=mongodb://user:pass@host:port/database
