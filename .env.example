# ============================================================
# yt-stack — biến môi trường
# Trên VPS: file .env do vps-agent TỰ SINH (lấy từ Hub khi đăng ký).
# Chạy thủ công / tham khảo: copy file này -> .env và điền giá trị thật.
#   cp .env.example .env
# ============================================================

# === Core Identity ===
SERVER_IP=203.0.113.45
SERVER_NAME=vps-xxxxxxxx

# === Domain ===
# Signed URL được build dạng: https://<DOWNLOAD_SUBDOMAIN>.<BASE_DOMAIN>
BASE_DOMAIN=yourdomain.com
DOWNLOAD_SUBDOMAIN=vps-xxxxxxxx
EMAIL=admin@yourdomain.com           # email Let's Encrypt (nginx/certbot)
PORT=5001                            # cổng yt-downloader BÊN TRONG container

# === Proxy Credentials (auth giữa downloader <-> gost; random mỗi VPS) ===
WARP_USER=changeme
WARP_PASS=changeme
DIRECT_USER=changeme
DIRECT_PASS=changeme

# === Storage & Download ===
STORAGE_DIR=./storage
DOWNLOAD_THREADS=4
CHUNK_SIZE=10000000
MAX_RETRIES=3
RETRY_DELAY_MS=100
CHUNK_TIMEOUT_S=30

# === Extract API ===
EXTRACT_API_TIMEOUT=10

# === Cleanup ===
CLEANUP_INTERVAL=*/3 * * * *
MAX_JOB_AGE_MIN=60
CLEANUP_BATCH_SIZE=5000

# === Security ===
SIGNED_URL_SECRET=change-me-32-chars-random
SIGNED_URL_EXPIRATION_MIN=60

# === Limits ===
MAX_TRIM_DURATION_MIN=1440
MAX_FILE_SIZE_GB=5

# === Feature Flags ===
ENABLE_MERGE=true
ENABLE_TRIM=true
ENABLE_REENCODE=true

# === Tier Config (theo customer tier: threads + rate byte/s) ===
TIER_CONFIG='{"0":{"threads":2,"rate":1048576},"1":{"threads":4,"rate":2097152}}'

# === Mongo Cookie Pool (YouTube / TikTok / Instagram) ===
# Cùng cluster với Hub; Hub dùng DB infra_registry, agent dùng DB cookie.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB=cookie

# === Hub Auth (phải KHỚP HUB_TOKEN bên Hub) ===
HUB_TOKEN=change-me-to-a-strong-secret

# === Platform Cookies (tùy chọn) ===
FB_DEFAULT_COOKIE=
X_DEFAULT_COOKIE=
